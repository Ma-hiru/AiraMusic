{
  "appId": "com.mahiru.airamusic",
  "productName": "AiraMusic",
  "files": [
    {
      "from": "app/dist/app/main.mjs",
      "to": "dist/app/main.mjs"
    },
    "app/package.json"
  ],
  "extraResources": [
    {
      "from": "ui/dist",
      "to": "ui"
    },
    {
      "from": "app/dist/preload/index.js",
      "to": "preload.js"
    },
    {
      "from": "app/assets",
      "to": "assets"
    }
  ],
  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "extraResources": [
      {
        "from": "store/server",
        "to": "bin/server"
      }
    ]
  },
  "win": {
    "target": "nsis",
    "extraResources": [
      {
        "from": "store/server.exe",
        "to": "bin/server.exe"
      }
    ]
  }
}
