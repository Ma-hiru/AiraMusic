{
  "appId": "com.mahiru.airamusic",
  "executableName": "AiraMusic",
  "productName": "AiraMusic",
  "directories": {
    "app": "packages/app",
    "output": "dist"
  },
  "files": ["dist/**/*", "package.json"],
  "extraResources": [
    {
      "from": "packages/ui/dist",
      "to": "ui"
    },
    {
      "from": "packages/app/dist/preload/index.js",
      "to": "preload.js"
    },
    {
      "from": "packages/app/assets",
      "to": "assets"
    }
  ],
  "linux": {
    "target": ["deb"],
    "icon": "packages/app/assets/logo.png",
    "category": "Utility",
    "extraResources": [
      {
        "from": "packages/store/dist/server",
        "to": "bin/server"
      }
    ]
  },
  "win": {
    "target": "nsis",
    "icon": "packages/app/assets/logo.png",
    "extraResources": [
      {
        "from": "packages/store/dist/server.exe",
        "to": "bin/server.exe"
      }
    ]
  }
}
