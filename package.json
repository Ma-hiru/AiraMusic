{
  "name": "simple-cloud-music",
  "description": "",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "Ma-hiru",
    "email": "tenshimahiru@qq.com"
  },
  "workspaces": [
    "ui",
    "wasm",
    "app"
  ],
  "scripts": {
    "dev:ui": "pnpm --filter @mahiru/ui run dev",
    "build:ui": "pnpm --filter @mahiru/ui run build",
    "preview:ui": "pnpm --filter @mahiru/ui run preview",
    "clear:wasm": "pnpm --filter @mahiru/wasm run clear",
    "build:wasm": "pnpm --filter @mahiru/wasm run build",
    "check": "tsgo --noEmit",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "format": "prettier --write .",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore --fix",
    "lint:eslint": "eslint . --fix"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "eslint": "^9",
    "eslint-plugin-oxlint": "latest",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.4",
    "@typescript/native-preview": "latest",
    "typescript": "^5",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "oxlint": "latest",
    "prettier": "latest",
    "stylelint": "^16",
    "stylelint-config-standard-scss": "^16",
    "typescript-eslint": "^8.46.3",
    "rimraf": "^6.1.0",
    "run-script-os": "^1.1.6"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.2.2"
    }
  }
}
