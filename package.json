{
  "name": "simple-cloud-music",
  "description": "",
  "type": "module",
  "main": "dist/app/main.mjs",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "Ma-hiru",
    "email": "tenshimahiru@qq.com",
    "github": "https://github.com/Ma-hiru"
  },
  "workspaces": [
    "app",
    "ui",
    "wasm"
  ],
  "scripts": {
    "dev:ui": "pnpm --filter @mahiru/ui run dev",
    "dev:electron": "pnpm --filter @mahiru/app run build && set NODE_ENV=development && electron .",
    "build:ui": "pnpm --filter @mahiru/ui run build",
    "preview:ui": "pnpm --filter @mahiru/ui run preview",
    "clear:wasm": "pnpm --filter @mahiru/wasm run clear",
    "build:wasm": "pnpm --filter @mahiru/wasm run build",
    "check": "tsgo --noEmit",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "format": "prettier --write .",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore --fix",
    "lint:eslint": "eslint . --fix",
    "commit:win32": "pnpm lint && pnpm exec pwsh ./git-commit.ps1",
    "commit:linux": "pnpm lint && pnpm exec ./git-commit.sh",
    "commit": "pnpm run-script-os"
  },
  "dependencies": {
    "electron": "^39.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@typescript/native-preview": "latest",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-oxlint": "latest",
    "eslint-plugin-prettier": "^5",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "oxlint": "latest",
    "prettier": "latest",
    "rimraf": "^6.1.0",
    "run-script-os": "^1.1.6",
    "stylelint": "^16",
    "stylelint-config-standard-scss": "^16",
    "typescript": "^5",
    "typescript-eslint": "^8.46.3",
    "tsup": "^8.5.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "esbuild"
    ]
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.2"
  }
}
