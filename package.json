{
  "name": "airamusic",
  "description": "A third party music player for Netease Music",
  "version": "1.0.0",
  "license": "",
  "homepage": "https://github.com/Ma-hiru/AiraMusic",
  "author": {
    "name": "Ma-hiru",
    "email": "tenshimahiru@qq.com",
    "github": "https://github.com/Ma-hiru"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "netease",
    "react",
    "网易云",
    "galss",
    "dynamic-theme"
  ],
  "workspaces": [
    "app",
    "ui",
    "wasm",
    "log",
    "store"
  ],
  "type": "module",
  "main": "dist/app/main.mjs",
  "private": true,
  "scripts": {
    "dev:ui": "pnpm --filter @mahiru/ui run dev",
    "dev:app": "shx cp .env ./app/.env && pnpm --filter @mahiru/app run dev",
    "dev:electron": "electron .",
    "preview:ui": "pnpm --filter @mahiru/ui run preview",
    "cache-clear": "rimraf ui/node_modules/.vite dist wasm/pkg",
    "build:ui": "pnpm --filter @mahiru/ui run build",
    "build:wasm": "pnpm --filter @mahiru/wasm run build",
    "build:store": "pnpm --filter @mahiru/store run build",
    "clear:wasm": "pnpm --filter @mahiru/wasm run clear",
    "commit": "pnpm check && pnpm format && pnpm lint && pnpm auto-commit",
    "check": "tsgo --noEmit",
    "format": "prettier --write .",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore --fix",
    "lint:eslint": "eslint . --fix",
    "auto-commit": "pnpm run-script-os",
    "auto-commit:win32": "pnpm exec pwsh ./scripts/git-commit.ps1",
    "auto-commit:linux": "pnpm exec bash ./scripts/git-commit.sh"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "electron": "^39.1.1",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.0",
    "@typescript/native-preview": "latest",
    "eslint": "^9.39.1",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "oxlint": "latest",
    "prettier": "latest",
    "rimraf": "^6.1.0",
    "run-script-os": "^1.1.6",
    "shx": "^0.4.0",
    "stylelint": "^16",
    "stylelint-config-standard-scss": "^16",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "typescript-eslint": "^8.46.3"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@applemusic-like-lyrics/core",
      "@applemusic-like-lyrics/lyric",
      "@parcel/watcher",
      "electron",
      "esbuild"
    ]
  }
}
