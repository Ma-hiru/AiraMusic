{
  "license": "MIT",
  "homepage": "https://github.com/Ma-hiru/AiraMusic",
  "author": {
    "name": "Ma-hiru",
    "email": "tenshimahiru@qq.com",
    "github": "https://github.com/Ma-hiru"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "netease",
    "react",
    "网易云",
    "galss",
    "dynamic-theme"
  ],
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "build": "yarn test && yarn build:wasm && yarn check && yarn lint && yarn build:store && yarn build:ui && yarn build:app && yarn build:electron",
    "dev": "yarn npm-run-all --parallel --race dev:ui dev:app dev:electron",
    "dev:ui": "yarn workspace @mahiru/ui dev",
    "dev:app": "yarn workspace airamusic dev",
    "dev:electron": "yarn wait-on http://localhost:8827 && yarn wait-on packages/app/dist/app/main.mjs && yarn electronmon ./packages/app --inspect=9229",
    "clean": "yarn clean:vite && yarn clean:cargo && yarn clean:go && yarn clean:dist",
    "clean:dist": "yarn rimraf dist && yarn workspace @mahiru/wasm clean:dist && yarn workspace @mahiru/store clean:dist && yarn workspace @mahiru/ui clean:dist && yarn workspace airamusic clean:dist",
    "clean:vite": "yarn rimraf ./ui/node_modules/.vite",
    "clean:cargo": "yarn workspace @mahiru/wasm clean:cargo",
    "clean:go": "yarn workspace @mahiru/store clean:go",
    "devtools:react": "yarn dlx react-devtools",
    "devtools:vue": "yarn dlx vue-devtools",
    "preview:ui": "yarn workspace @mahiru/ui preview",
    "build:ui": "yarn workspace @mahiru/ui build",
    "build:app": "yarn workspace airamusic build",
    "build:wasm": "yarn workspace @mahiru/wasm build",
    "build:store": "yarn workspace @mahiru/store build",
    "build:electron": "yarn run-script-os",
    "build:electron:linux": "yarn electron-builder build --linux",
    "build:electron:win32": "yarn electron-builder build --windows",
    "commit": "yarn check && yarn lint && yarn auto-commit",
    "check": "yarn tsgo --noEmit",
    "lint": "yarn check && yarn lint:ts && yarn lint:wasm && yarn lint:store",
    "lint:ts": "yarn prettier --write . && yarn eslint . --fix",
    "lint:wasm": "yarn workspace @mahiru/wasm lint",
    "lint:store": "yarn workspace @mahiru/store lint",
    "test": "yarn test:wasm && yarn test:store",
    "test:wasm": "yarn workspace @mahiru/wasm test",
    "test:store": "yarn workspace @mahiru/store test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.1",
    "@vue/devtools": "^8.0.5",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.14.0",
    "jiti": "^2.6.1",
    "npm-run-all": "^4.1.5",
    "prettier": "latest",
    "react-devtools": "^7.0.1",
    "rimraf": "^6.1.0",
    "run-script-os": "^1.1.6",
    "sharp": "^0.34.5",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.3",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "electronmon": {
    "patterns": [
      "!**/*",
      "app/dist/**/*"
    ]
  },
  "packageManager": "yarn@4.14.1"
}
